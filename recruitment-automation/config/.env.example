# ── Email (IMAP) ────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_TLS=true
IMAP_USER=your@gmail.com
# Use App Password for Gmail (not your main password)
# Generate at: https://myaccount.google.com/apppasswords
IMAP_PASSWORD=your_app_password
IMAP_MAILBOX=INBOX
IMAP_PROCESSED_LABEL=Processed/Recruitment
# Comma-separated sender domains/emails to watch for (empty = all)
IMAP_FILTER_FROM=

# ── AI Extraction ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-opus-4-7
AI_MAX_TOKENS=2048

# ── HRappka ─────────────────────────────────────────────────
HRAPPKA_URL=https://app.hrappka.pl
HRAPPKA_EMAIL=admin@yourcompany.pl
HRAPPKA_PASSWORD=your_hrappka_password
# Optional: use macOS Keychain instead (recommended)
HRAPPKA_USE_KEYCHAIN=false

# ── Database ─────────────────────────────────────────────────
DB_PATH=./data/recruitment.db

# ── Paths ────────────────────────────────────────────────────
PDF_ARCHIVE_DIR=./archives/pdfs
LOG_DIR=./logs
SCREENSHOTS_DIR=./logs/screenshots

# ── Polling ─────────────────────────────────────────────────
# How often to check for new emails (seconds)
EMAIL_POLL_INTERVAL=60

# ── Retry ───────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY_MS=5000

# ── Apple Notes ─────────────────────────────────────────────
NOTES_FOLDER=Recruitment
