# Required
ANTHROPIC_API_KEY=sk-ant-...

# Watch settings
WATCH_FOLDER=~/Documents/Translate Inbox
WATCH_INTERVAL_MS=10000
WATCH_EXTENSIONS=.pdf,.txt,.md,.html,.htm,.csv

# Claude AI settings
AI_MODEL=claude-haiku-4-5-20251001
AI_MAX_TOKENS=4096
# Override the default Polish translation prompt:
# TRANSLATION_PROMPT=Summarize the following document in 3 bullet points.

# Apple Notes
NOTES_FOLDER=Translated Documents

# Paths
STATE_FILE=./data/processed.json
LOG_DIR=./logs
